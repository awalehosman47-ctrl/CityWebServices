reviews.citywebservices.site
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rate Your Experience - City Web Services</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
    .card { background: white; max-width: 420px; width: 100%; padding: 40px 30px; border-radius: 24px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); text-align: center; }
    .logo { font-size: 4em; margin-bottom: 15px; }
    h1 { color: #1a202c; font-size: 1.8em; margin-bottom: 8px; font-weight: 700; }
    .clinic { color: #4a5568; margin-bottom: 10px; font-size: 1.1em; }
    .subtitle { color: #718096; margin-bottom: 30px; font-size: 0.95em; }
    .stars { font-size: 3em; margin: 25px 0; cursor: pointer; display: flex; justify-content: center; gap: 8px; }
    .star { transition: all 0.3s ease; padding: 5px; opacity: 0.4; filter: grayscale(100%); cursor: pointer; }
    .star:hover, .star.active { opacity: 1; filter: grayscale(0%); transform: scale(1.3); }
    .star.active { filter: drop-shadow(0 0 15px rgba(255,215,0,0.6)); }
    #rating-text { color: #4a5568; margin-top: 15px; font-weight: 600; min-height: 24px; font-size: 1.1em; }
    .btn { display: block; width: 100%; padding: 18px; border: none; border-radius: 14px; font-size: 1.1em; font-weight: 700; cursor: pointer; margin-top: 25px; text-decoration: none; transition: all 0.3s ease; }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0,0,0,0.2); }
    .google-btn { background: linear-gradient(135deg, #4285F4 0%, #34a853 100%); color: white; }
    .submit-btn { background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%); color: white; }
    .hidden { display: none !important; }
    textarea { width: 100%; padding: 18px; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 1em; margin-top: 20px; min-height: 120px; resize: vertical; font-family: inherit; }
    textarea:focus { outline: none; border-color: #667eea; }
    .success { color: #065f46; background: #d1fae5; padding: 25px; border-radius: 14px; margin-top: 25px; font-weight: 600; }
  </style>
</head>
<body>

<!-- STEP 1: Star Rating -->
<div class="card" id="step1">
  <div class="logo">😊</div>
  <h1>How Was Your Experience?</h1>
  <p class="clinic">City Web Services</p>
  <p class="subtitle">Your feedback helps us serve you better</p>
  
  <div class="stars" id="stars">
    <span class="star" data-rating="1">⭐</span>
    <span class="star" data-rating="2">⭐</span>
    <span class="star" data-rating="3">⭐</span>
    <span class="star" data-rating="4">⭐</span>
    <span class="star" data-rating="5">⭐</span>
  </div>
  
  <p id="rating-text"></p>
</div>

<!-- STEP 2: Positive (4-5 stars) -->
<div class="card hidden" id="step2-positive">
  <div class="logo">🎉</div>
  <h1>Thank You!</h1>
  <p class="clinic">We're thrilled you had a great experience!</p>
  <p class="subtitle">Would you mind sharing your feedback on Google? It helps other patients find us.</p>
  
  <a href="https://citywebservices.site/review" class="btn google-btn" target="_blank" rel="noopener">
    ⭐ Leave a Google Review
  </a>
</div>

<!-- STEP 3: Negative (1-3 stars) -->
<div class="card hidden" id="step2-negative">
  <div class="logo">🙏</div>
  <h1>We're Sorry</h1>
  <p class="clinic">We'd love to make things right.</p>
  <p class="subtitle">Your feedback goes directly to our team.</p>
  
  <form action="https://formspree.io/f/xvzdrvld" method="POST" id="negative-form">
    <input type="hidden" name="rating" id="form-rating" value="">
    <input type="hidden" name="clinic" value="City Web Services">
    <input type="hidden" name="source" value="Review Funnel">
    <input type="hidden" name="_replyto" value="info@citywebservices.site">
    
    <textarea name="feedback" placeholder="Tell us what went wrong so we can improve..." required></textarea>
    
    <button type="submit" class="btn submit-btn">Send Feedback</button>
  </form>
  
  <div class="success hidden" id="success-msg">
    ✅ Thank you for your feedback. We'll be in touch soon!
  </div>
</div>

<script>
  const stars = document.querySelectorAll('.star');
  let selectedRating = 0;

  stars.forEach(star => {
    star.addEventListener('click', function() {
      selectedRating = parseInt(this.getAttribute('data-rating'));
      
      stars.forEach((s, index) => {
        if (index < selectedRating) {
          s.classList.add('active');
        } else {
          s.classList.remove('active');
        }
      });

      const texts = ['Terrible', 'Bad', 'Okay', 'Good', 'Excellent!'];
      document.getElementById('rating-text').textContent = texts[selectedRating - 1];

      setTimeout(() => {
        document.getElementById('form-rating').value = selectedRating;
        document.getElementById('step1').classList.add('hidden');
        
        if (selectedRating >= 4) {
          document.getElementById('step2-positive').classList.remove('hidden');
        } else {
          document.getElementById('step2-negative').classList.remove('hidden');
        }
      }, 600);
    });
  });

  document.getElementById('negative-form').addEventListener('submit', function() {
    setTimeout(() => {
      this.classList.add('hidden');
      document.getElementById('success-msg').classList.remove('hidden');
    }, 500);
  });
</script>

</body>
</html>
